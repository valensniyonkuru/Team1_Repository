# .env.staging - Staging environment variables template
# Copy to .env and update values for staging deployment

# Database Configurations
DB_NAME=communityboard
DB_USER=postgres
DB_PASSWORD=staging-db-password-change-me

# Application Configuration
SPRING_PROFILES=staging
JWT_SECRET=staging-jwt-secret-change-me

# Frontend Configuration
REACT_APP_API_URL=http://staging-api.example.com

# Docker Image Registry
# Required to pull images: docker-compose.staging.yml uses
# ${DOCKER_REGISTRY}/${DOCKER_NAMESPACE}/communityboard-*:staging
DOCKER_REGISTRY=docker.io
DOCKER_NAMESPACE=CHANGE_TO_YOUR_DOCKERHUB_USERNAME

# Container Configuration
COMPOSE_PROJECT_NAME=communityboard-staging
