#!/bin/bash
# Pre-commit hook to run basic checks and validations

echo "==========================================="
echo "🏃 Running pre-commit checks..."
echo "==========================================="

# Ensure we're in the repository root
REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT" || exit 1

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Flag to track overall success
FAILED=0

# 1. 🛑 Prevent committing directly to main/develop branches
BRANCH_NAME=$(git rev-parse --abbrev-ref HEAD)
if [[ "$BRANCH_NAME" == "main" || "$BRANCH_NAME" == "production" ]]; then
    echo -e "${RED}❌ Error: You cannot commit directly to the '$BRANCH_NAME' branch.${NC}"
    echo -e "${YELLOW}Please create a feature branch, commit there, and open a Pull Request.${NC}"
    exit 1
fi

# 2. 🤫 Check for accidental hardcoded secrets
echo "🔍 Checking for hardcoded secrets..."
SECRET_PATTERN="(password|secret|token|api_key|access_key)[\s]*=[\s]*[\"'][^\"']+[\"']"
# Scan only staggered/staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -n "$STAGED_FILES" ]; then
    for FILE in $STAGED_FILES; do
        if git diff --cached "$FILE" | grep -iE "$SECRET_PATTERN" > /dev/null; then
            echo -e "${RED}⚠️  WARNING: Potential hardcoded secret found in $FILE${NC}"
            echo -e "Please use environment variables (.env) or GitHub Secrets instead."
            # Uncomment the next line to STRICTLY block commits with secrets
            # FAILED=1
        fi
    done
fi

# 3. 📦 Check for large file commits (>50MB)
echo "📁 Checking for large files..."
if [ -n "$STAGED_FILES" ]; then
    for FILE in $STAGED_FILES; do
        if [ -f "$FILE" ]; then
            FILE_SIZE=$(wc -c < "$FILE")
            # 50MB in bytes
            if [ "$FILE_SIZE" -gt 52428800 ]; then
                echo -e "${RED}❌ Error: File '$FILE' is too large ($((FILE_SIZE/1048576))MB). Maximum size is 50MB.${NC}"
                FAILED=1
            fi
        fi
    done
fi

# 4. 🚀 Check Dockerfile structures lazily
if echo "$STAGED_FILES" | grep -q "Dockerfile"; then
    echo "🐳 Validating Dockerfiles..."
    for DFILE in $(echo "$STAGED_FILES" | grep "Dockerfile"); do
        if grep -q "latest" "$DFILE"; then
            echo -e "${YELLOW}⚠️ Notice: Found 'latest' tag in $DFILE. Pinning explicit versions is recommended for production.${NC}"
        fi
    done
fi

if [ $FAILED -ne 0 ]; then
    echo "==========================================="
    echo -e "${RED}❌ Pre-commit checks failed! Please fix the errors above.${NC}"
    echo "==========================================="
    exit 1
fi

echo -e "${GREEN}✅ All checks passed! Proceeding with commit.${NC}"
echo "==========================================="
exit 0
