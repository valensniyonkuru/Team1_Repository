# .env.production - Production environment variables template
# Copy to .env and update values for production deployment
# IMPORTANT: Never commit .env with real secrets - use GitHub Secrets in CI/CD

# Database Configuration
DB_NAME=communityboard
DB_USER=postgres
DB_PASSWORD=CHANGE_TO_STRONG_PASSWORD

# Application Configuration
SPRING_PROFILES=production
JWT_SECRET=CHANGE_TO_SECURE_SECRET_KEY
SERVER_PORT=8080

# CORS / Frontend URL
FRONTEND_URL=https://your-production-domain.com
CORS_ALLOWED_ORIGINS=https://your-production-domain.com

# Frontend Configuration
REACT_APP_API_URL=https://api.your-production-domain.com

# Email Configuration
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Seed Data (ETL)
SEED_ADMIN_EMAIL=admin@yourdomain.com
SEED_ADMIN_NAME=Admin User
SEED_USER_EMAIL=user@yourdomain.com
SEED_USER_NAME=Test User

# Docker Image Registry
# Required to pull images: docker-compose.production.yml uses
# ${DOCKER_REGISTRY}/${DOCKER_NAMESPACE}/communityboard-*:latest
DOCKER_REGISTRY=docker.io
DOCKER_NAMESPACE=CHANGE_TO_YOUR_DOCKERHUB_USERNAME

# Container Configuration
COMPOSE_PROJECT_NAME=communityboard-production
