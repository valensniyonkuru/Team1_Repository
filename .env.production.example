# .env.production - Production environment variables template
# Copy to .env and update values for production deployment
# IMPORTANT: Never commit .env with real secrets - use GitHub Secrets in CI/CD

# Database Configuration
DB_NAME=communityboard
DB_USER=postgres
DB_PASSWORD=CHANGE_TO_STRONG_PASSWORD

# Application Configuration
SPRING_PROFILES=production
JWT_SECRET=CHANGE_TO_SECURE_SECRET_KEY

# Frontend Configuration
REACT_APP_API_URL=https://api.example.com

# Container Configuration
COMPOSE_PROJECT_NAME=communityboard-production
