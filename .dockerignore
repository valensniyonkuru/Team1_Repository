.git
.gitignore
.gitattributes

# Version control
.github
.gitlab-ci.yml
.gitlab

# IDEs and editors
.vscode
.idea
*.swp
*.swo
*~
.DS_Store
*.iml
*.sublime-project
*.sublime-workspace

